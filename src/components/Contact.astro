---
---
<!-- Catering CTA — Kerala themed -->
<section class="py-14 md:py-20 bg-gold text-center relative overflow-hidden">
    <!-- Decorative pattern -->
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;80&quot; height=&quot;80&quot; viewBox=&quot;0 0 80 80&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%231e4a30&quot;%3E%3Ccircle cx=&quot;40&quot; cy=&quot;40&quot; r=&quot;3&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="w-full max-w-3xl mx-auto px-4 sm:px-6 reveal relative z-10">
        <span class="text-4xl mb-4 block">🎉</span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading text-primary leading-tight mb-3">Planning an Event?</h2>
        <p class="text-primary/60 max-w-lg mx-auto text-sm sm:text-base mb-8">We offer catering for all occasions — weddings, corporate events, and private parties. Authentic Kerala flavours for your special day.</p>
        <a href="#contact" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full font-semibold text-sm transition-all duration-300 bg-primary text-white shadow-lg hover:bg-primary-light hover:-translate-y-0.5 hover:shadow-xl">Inquire About Catering</a>
    </div>
</section>

<!-- Testimonials -->
<section class="py-16 md:py-24 bg-bg-main">
    <div class="w-full max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 reveal">
            <div class="flex items-center justify-center gap-3 mb-4">
                <div class="w-8 h-[2px] bg-gold/50"></div>
                <span class="text-accent font-semibold uppercase tracking-[3px] text-xs">Testimonials</span>
                <div class="w-8 h-[2px] bg-gold/50"></div>
            </div>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading text-primary leading-tight">What Our Customers Say</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white p-6 sm:p-8 rounded-2xl reveal border border-gold/10 shadow-sm hover:shadow-md transition-shadow">
                <div class="text-gold mb-3 text-sm tracking-widest">★★★★★</div>
                <p class="text-gray-500 mb-5 text-sm sm:text-[0.9rem] leading-relaxed">"We ordered biryani for 25 people, and overall, the experience was great. The food was flavorful and well-prepared, and everyone enjoyed it."</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">B</div>
                    <div>
                        <span class="text-primary font-medium text-sm block">Basil Paul</span>
                        <span class="text-gray-400 text-xs">Google Review</span>
                    </div>
                </div>
            </div>
            <div class="bg-white p-6 sm:p-8 rounded-2xl reveal delay-1 border border-gold/10 shadow-sm hover:shadow-md transition-shadow">
                <div class="text-gold mb-3 text-sm tracking-widest">★★★★★</div>
                <p class="text-gray-500 mb-5 text-sm sm:text-[0.9rem] leading-relaxed">"Customer friendly staff and tasty food. The Chilli-pork with Paratha was delicious. People who love spicy food can try this. Enjoyed."</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-bold text-sm">D</div>
                    <div>
                        <span class="text-primary font-medium text-sm block">Denn P</span>
                        <span class="text-gray-400 text-xs">Google Review</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact -->
<section id="contact" class="py-16 md:py-24 bg-white relative">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    <div class="w-full max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 reveal">
            <div class="flex items-center justify-center gap-3 mb-4">
                <div class="w-8 h-[2px] bg-gold/50"></div>
                <span class="text-accent font-semibold uppercase tracking-[3px] text-xs">Get In Touch</span>
                <div class="w-8 h-[2px] bg-gold/50"></div>
            </div>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading text-primary leading-tight mb-3">Visit Our Kitchen</h2>
            <p class="text-gray-400 max-w-md mx-auto text-sm sm:text-base">We're always happy to serve you.</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal">
                <div class="bg-bg-main p-5 sm:p-6 rounded-2xl border border-gold/10 shadow-sm hover:shadow-md transition-shadow group">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform inline-block">📍</div>
                    <h4 class="text-primary font-heading font-bold text-base mb-1">Location</h4>
                    <p class="text-gray-500 text-sm">147/149 Ohaupo Road,<br>Melville, Hamilton 3206</p>
                </div>
                <div class="bg-bg-main p-5 sm:p-6 rounded-2xl border border-gold/10 shadow-sm hover:shadow-md transition-shadow group">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform inline-block">📞</div>
                    <h4 class="text-primary font-heading font-bold text-base mb-1">Contact</h4>
                    <p class="text-sm"><a href="tel:078430307" class="text-gray-500 hover:text-accent transition-colors">07 843 0307</a></p>
                    <p class="text-sm"><a href="tel:02108397130" class="text-gray-500 hover:text-accent transition-colors">021 0839 7130</a></p>
                </div>
                <div class="bg-bg-main p-5 sm:p-6 rounded-2xl border border-gold/10 shadow-sm hover:shadow-md transition-shadow group">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform inline-block">📧</div>
                    <h4 class="text-primary font-heading font-bold text-base mb-1">Email</h4>
                    <p class="text-sm"><a href="mailto:malluscorner.nz@gmail.com" class="text-gray-500 hover:text-accent transition-colors break-all">malluscorner.nz@gmail.com</a></p>
                </div>
                <div class="bg-bg-main p-5 sm:p-6 rounded-2xl border border-gold/10 shadow-sm hover:shadow-md transition-shadow group">
                    <div class="text-2xl mb-3 group-hover:scale-110 transition-transform inline-block">🕒</div>
                    <h4 class="text-primary font-heading font-bold text-base mb-1">Hours</h4>
                    <p class="text-gray-500 text-sm">Open 7 Days<br>12:00 PM – 9:00 PM</p>
                </div>
            </div>
            <div class="h-[280px] sm:h-[300px] md:h-[380px] rounded-2xl overflow-hidden shadow-md reveal delay-1 border border-gold/10">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.2536838384814!2d175.2758!3d-37.8105!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6d6d190000000001%3A0x0!2zMTQ3IE9oYXVwbyBSZCwgTWVsdmlsbGUsIEhhbWlsdG9uIDMyMDYsIE5ldyBaZWFsYW5k!5e0!3m2!1sen!2snz!4v1620000000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" title="Mallu's Corner Location"></iframe>
            </div>
        </div>
    </div>
</section>
