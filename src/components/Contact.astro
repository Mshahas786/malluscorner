<!-- Catering CTA -->
<section class="py-14 md:py-20 bg-[#1e4a30] text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="w-full max-w-3xl mx-auto px-5 reveal relative z-10">
        <h2 class="text-2xl md:text-3xl font-heading text-white leading-tight mb-3">Planning an Event?</h2>
        <p class="text-white/60 max-w-lg mx-auto text-sm mb-6">We offer catering for all occasions — weddings, corporate events, and private parties.</p>
        <a href="#contact" class="inline-flex items-center justify-center px-6 py-3 rounded-full font-semibold text-sm transition-all duration-300 bg-[#c75438] text-white shadow-lg hover:bg-[#b0462e] hover:-translate-y-0.5 hover:shadow-xl">Inquire About Catering</a>
    </div>
</section>

<!-- Testimonials -->
<section class="py-16 md:py-24 bg-white">
    <div class="w-full max-w-5xl mx-auto px-5">
        <div class="text-center mb-10 reveal">
            <span class="inline-block text-[#c75438] font-semibold uppercase tracking-[3px] text-xs mb-4">Testimonials</span>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading text-[#1e4a30] leading-tight">What Our Customers Say</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-[#faf8f5] p-6 md:p-8 rounded-2xl reveal border border-gray-100">
                <div class="text-[#dca43b] mb-3 text-sm tracking-widest">★★★★★</div>
                <p class="text-gray-500 mb-5 text-[0.9rem] leading-relaxed">"We ordered biryani for 25 people, and overall, the experience was great. The food was flavorful and well-prepared, and everyone enjoyed it."</p>
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-[#1e4a30] text-white flex items-center justify-center font-bold text-sm">B</div>
                    <span class="text-[#1e4a30] font-medium text-sm">Basil Paul</span>
                </div>
            </div>
            <div class="bg-[#faf8f5] p-6 md:p-8 rounded-2xl reveal delay-1 border border-gray-100">
                <div class="text-[#dca43b] mb-3 text-sm tracking-widest">★★★★★</div>
                <p class="text-gray-500 mb-5 text-[0.9rem] leading-relaxed">"Customer friendly staff and tasty food. The Chilli-pork with Paratha was delicious. People who love spicy food can try this. Enjoyed."</p>
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-[#c75438] text-white flex items-center justify-center font-bold text-sm">D</div>
                    <span class="text-[#1e4a30] font-medium text-sm">Denn P</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact -->
<section id="contact" class="py-16 md:py-24 bg-[#faf8f5]">
    <div class="w-full max-w-6xl mx-auto px-5">
        <div class="text-center mb-10 reveal">
            <span class="inline-block text-[#c75438] font-semibold uppercase tracking-[3px] text-xs mb-4">Get In Touch</span>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading text-[#1e4a30] leading-tight mb-3">Visit Our Kitchen</h2>
            <p class="text-gray-400 max-w-md mx-auto text-[0.95rem]">We're always happy to serve you.</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal">
                <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-2xl mb-2">📍</div>
                    <h4 class="text-[#1e4a30] font-heading font-bold text-base mb-1">Location</h4>
                    <p class="text-gray-500 text-sm">147/149 Ohaupo Road,<br>Melville, Hamilton 3206</p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-2xl mb-2">📞</div>
                    <h4 class="text-[#1e4a30] font-heading font-bold text-base mb-1">Contact</h4>
                    <p class="text-sm"><a href="tel:078430307" class="text-gray-500 hover:text-[#c75438] transition-colors">07 843 0307</a></p>
                    <p class="text-sm"><a href="tel:02108397130" class="text-gray-500 hover:text-[#c75438] transition-colors">021 0839 7130</a></p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-2xl mb-2">📧</div>
                    <h4 class="text-[#1e4a30] font-heading font-bold text-base mb-1">Email</h4>
                    <p class="text-sm"><a href="mailto:malluscorner.nz@gmail.com" class="text-gray-500 hover:text-[#c75438] transition-colors break-all">malluscorner.nz@gmail.com</a></p>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                    <div class="text-2xl mb-2">🕒</div>
                    <h4 class="text-[#1e4a30] font-heading font-bold text-base mb-1">Hours</h4>
                    <p class="text-gray-500 text-sm">Open 7 Days<br>11:00 AM – 9:00 PM</p>
                </div>
            </div>
            <div class="h-[300px] md:h-[380px] rounded-2xl overflow-hidden shadow-sm reveal delay-1 border border-gray-100">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.2536838384814!2d175.2758!3d-37.8105!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6d6d190000000001%3A0x0!2zMTQ3IE9oYXVwbyBSZCwgTWVsdmlsbGUsIEhhbWlsdG9uIDMyMDYsIE5ldyBaZWFsYW5k!5e0!3m2!1sen!2snz!4v1620000000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" title="Mallu's Corner Location"></iframe>
            </div>
        </div>
    </div>
</section>
