---
---
<section id="gallery" class="py-16 md:py-24 bg-[#f7f4ef]">
    <div class="w-full max-w-6xl mx-auto px-5">
        <div class="text-center mb-10 reveal">
            <span class="inline-block text-[#c75438] font-semibold uppercase tracking-[3px] text-xs mb-4">Visual Delight</span>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading text-[#1e4a30] leading-tight mb-4">Our Gallery</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
            <img 
                src="https://images.pexels.com/photos/2474661/pexels-photo-2474661.jpeg?auto=compress&cs=tinysrgb&w=600" 
                alt="Kerala Chicken Dish" 
                class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal"
                loading="lazy"
            />
            <img 
                src="https://images.pexels.com/photos/1624487/pexels-photo-1624487.jpeg?auto=compress&cs=tinysrgb&w=600" 
                alt="Indian Spices" 
                class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal delay-1"
                loading="lazy"
            />
            <img 
                src="https://images.pexels.com/photos/958545/pexels-photo-958545.jpeg?auto=compress&cs=tinysrgb&w=600" 
                alt="Traditional Kerala Meal" 
                class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal delay-2"
                loading="lazy"
            />
            <img 
                src="https://images.pexels.com/photos/1352270/pexels-photo-1352270.jpeg?auto=compress&cs=tinysrgb&w=600" 
                alt="Kerala Biriyani" 
                class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal delay-1"
                loading="lazy"
            />
        </div>
    </div>
</section>
