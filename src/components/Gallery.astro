---
---
<section id="gallery" class="py-16 md:py-24 bg-[#f7f4ef]">
    <div class="w-full max-w-6xl mx-auto px-5">
        <div class="text-center mb-10 reveal">
            <span class="inline-block text-[#c75438] font-semibold uppercase tracking-[3px] text-xs mb-4">Visual Delight</span>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading text-[#1e4a30] leading-tight mb-4">Our Gallery</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
            <!-- Using gradient placeholders instead of broken external image URLs -->
            <div class="rounded-2xl aspect-square shadow-sm w-full reveal overflow-hidden bg-gradient-to-br from-[#dca43b]/30 to-[#c75438]/20 flex items-center justify-center text-4xl">🍗</div>
            <div class="rounded-2xl aspect-square shadow-sm w-full reveal delay-1 overflow-hidden bg-gradient-to-br from-[#1e4a30]/20 to-[#2d6b46]/10 flex items-center justify-center text-4xl">🥘</div>
            <div class="rounded-2xl aspect-square shadow-sm w-full reveal delay-2 overflow-hidden bg-gradient-to-br from-[#c75438]/20 to-[#dca43b]/10 flex items-center justify-center text-4xl">🌶️</div>
            <div class="rounded-2xl aspect-square shadow-sm w-full reveal delay-1 overflow-hidden bg-gradient-to-br from-[#2d6b46]/20 to-[#1e4a30]/10 flex items-center justify-center text-4xl">🍛</div>
        </div>
    </div>
</section>
