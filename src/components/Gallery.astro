---
<section id="gallery" class="py-20 md:py-28 bg-[#f1ebd9]">
    <div class="w-full max-w-7xl mx-auto px-5">
        <div class="text-center mb-12 reveal">
            <span class="inline-block text-[#c75438] font-semibold uppercase tracking-[2px] text-[0.85rem] mb-3">Visual Delight</span>
            <h2 class="text-3xl md:text-4xl lg:text-[3.2rem] font-heading text-[#1e4a30] leading-tight mb-6">Our Gallery</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <img src="https://images.unsplash.com/photo-1593432316892-10bb4f131a4d?auto=format&fit=crop&w=600&q=80" alt="Kerala Chicken Dish" class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal" />
            <img src="https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=600&q=80" alt="Fresh Ingredients" class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal delay-1" />
            <img src="https://images.unsplash.com/photo-1589187151003-0dd55769239b?auto=format&fit=crop&w=600&q=80" alt="Spices" class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal delay-2" />
            <img src="https://images.unsplash.com/photo-1606491956689-2ea8c5119c85?auto=format&fit=crop&w=600&q=80" alt="Kerala Meal" class="rounded-2xl object-cover aspect-square shadow-sm w-full reveal delay-1" />
        </div>
    </div>
</section>
