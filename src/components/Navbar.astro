---
---
<header class="fixed top-0 left-0 w-full bg-white/90 backdrop-blur-lg shadow-[0_1px_3px_rgba(0,0,0,0.06)] z-50 transition-all duration-300" id="navbar">
    <div class="w-full max-w-7xl mx-auto px-5 flex justify-between items-center h-16 md:h-[72px]">
        <a href="#" class="relative z-[61] flex items-center group">
            <span class="font-heading text-[#1e4a30] text-xl md:text-2xl font-bold tracking-tight transition-colors group-hover:text-[#c75438]">Mallu's Corner</span>
        </a>
        <button class="flex flex-col justify-center items-center gap-[5px] bg-transparent border-none cursor-pointer z-[61] relative w-10 h-10 lg:hidden" aria-label="Toggle menu" id="mobile-menu-btn">
            <span class="block w-6 h-[2.5px] rounded-full bg-[#1e4a30] transition-all duration-300 origin-center" id="bar1"></span>
            <span class="block w-6 h-[2.5px] rounded-full bg-[#1e4a30] transition-all duration-300" id="bar2"></span>
            <span class="block w-6 h-[2.5px] rounded-full bg-[#1e4a30] transition-all duration-300 origin-center" id="bar3"></span>
        </button>
        <nav class="fixed inset-0 bg-[#faf8f5] flex flex-col items-center justify-center gap-8 transition-all duration-500 ease-in-out z-[60] opacity-0 pointer-events-none translate-y-[-10px] [&.active]:opacity-100 [&.active]:pointer-events-auto [&.active]:translate-y-0 lg:static lg:bg-transparent lg:flex-row lg:opacity-100 lg:pointer-events-auto lg:gap-8 lg:translate-y-0" id="nav-links">
            <a href="#home" class="text-[#1e4a30] text-2xl font-body font-semibold lg:text-[0.95rem] lg:font-medium lg:text-gray-600 hover:text-[#c75438] transition-colors">Home</a>
            <a href="#about" class="text-[#1e4a30] text-2xl font-body font-semibold lg:text-[0.95rem] lg:font-medium lg:text-gray-600 hover:text-[#c75438] transition-colors">Our Story</a>
            <a href="#menu" class="text-[#1e4a30] text-2xl font-body font-semibold lg:text-[0.95rem] lg:font-medium lg:text-gray-600 hover:text-[#c75438] transition-colors">Menu</a>
            <a href="#gallery" class="text-[#1e4a30] text-2xl font-body font-semibold lg:text-[0.95rem] lg:font-medium lg:text-gray-600 hover:text-[#c75438] transition-colors">Gallery</a>
            <a href="#contact" class="text-[#1e4a30] text-2xl font-body font-semibold lg:text-[0.95rem] lg:font-medium lg:text-gray-600 hover:text-[#c75438] transition-colors">Contact</a>
            <a href="tel:078430307" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-bold text-base bg-[#c75438] text-white shadow-lg hover:bg-[#b0462e] hover:shadow-xl lg:px-5 lg:py-2 lg:text-sm lg:ml-2">📞 Call Now</a>
        </nav>
    </div>
</header>

<script>
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const navLinks = document.getElementById('nav-links');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');
    
    if (mobileMenuBtn && navLinks) {
        mobileMenuBtn.addEventListener('click', () => {
            const isOpen = navLinks.classList.toggle('active');
            if (isOpen) {
                bar1.style.transform = 'rotate(45deg) translate(3px, 3px)';
                bar2.style.opacity = '0';
                bar3.style.transform = 'rotate(-45deg) translate(3px, -3px)';
                bar1.style.background = 'white';
                bar2.style.background = 'white';
                bar3.style.background = 'white';
            } else {
                bar1.style.transform = 'none';
                bar2.style.opacity = '1';
                bar3.style.transform = 'none';
                bar1.style.background = '#1e4a30';
                bar2.style.background = '#1e4a30';
                bar3.style.background = '#1e4a30';
            }
        });

        navLinks.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                navLinks.classList.remove('active');
                bar1.style.transform = 'none';
                bar2.style.opacity = '1';
                bar3.style.transform = 'none';
                bar1.style.background = '#1e4a30';
                bar2.style.background = '#1e4a30';
                bar3.style.background = '#1e4a30';
            });
        });
    }
</script>
