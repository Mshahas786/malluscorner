<section id="menu" class="py-20 md:py-28 bg-[#faf8f5]">
    <div class="w-full max-w-7xl mx-auto px-5">
        <div class="text-center mb-12 reveal">
            <span class="inline-block text-[#c75438] font-semibold uppercase tracking-[2px] text-[0.85rem] mb-3">Taste the Tradition</span>
            <h2 class="text-3xl md:text-4xl lg:text-[3.2rem] font-heading text-[#1e4a30] leading-tight mb-6">Our Food Menu</h2>
            <p class="text-gray-500 max-w-[600px] mx-auto text-[1.1rem]">Indulge in our vibrant menu featuring authentic Kerala flavors and eclectic cuisine.</p>
        </div>

        <div class="reveal delay-1">
            <div class="block lg:hidden mb-8">
                <select id="mobile-menu-select" aria-label="Select Menu Category" class="w-full p-4 border border-black/10 rounded-2xl bg-[#1e4a30] text-white text-[1.1rem] font-body font-medium outline-none shadow-sm appearance-none">
                    {Object.keys(menuData).map((cat) => (
                        <option value={cat}>{cat.charAt(0).toUpperCase() + cat.slice(1)}</option>
                    ))}
                </select>
            </div>

            <div class="hidden lg:flex flex-wrap justify-center gap-3 mb-10" id="menu-tabs">
                {Object.keys(menuData).map((cat) => (
                    <button class="tab-btn px-6 py-2.5 bg-transparent border-2 border-[#1e4a30] text-[#1e4a30] font-body font-semibold rounded-full cursor-pointer transition-colors hover:bg-[#1e4a30] hover:text-white [&.active]:bg-[#1e4a30] [&.active]:text-white" data-category={cat}>
                        {cat.charAt(0).toUpperCase() + cat.slice(1)}
                    </button>
                ))}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-5" id="menu-grid">
                <!-- Javascript will handle the dynamic rendering to maintain the same interactive behavior -->
            </div>
        </div>
    </div>
</section>

<script define:vars={{ menuData }}>
    const menuGrid = document.getElementById('menu-grid');
    const tabBtns = document.querySelectorAll('.tab-btn');
    const mobileSelect = document.getElementById('mobile-menu-select');

    function renderMenu(category) {
        if (!menuGrid) return;
        
        menuGrid.innerHTML = '';
        const items = menuData[category] || [];
        
        items.forEach((item, index) => {
            const el = document.createElement('div');
            el.className = 'reveal bg-[#faf8f5] p-6 rounded-2xl shadow-[0_4px_15px_rgba(0,0,0,0.04)] flex justify-between items-center border border-[#dca43b]/20 relative overflow-hidden transition-all duration-300 z-10 hover:-translate-y-1.5 hover:shadow-[0_8px_25px_rgba(30,74,48,0.1)] hover:border-[#dca43b] group';
            el.style.transitionDelay = `${index * 0.05}s`;
            
            // Add pseudo-element effect manually since it's hard with standard Tailwind in dynamic JS without more config
            const bgHover = document.createElement('div');
            bgHover.className = 'absolute top-0 left-0 h-full w-1 bg-[#dca43b] transition-all duration-300 -z-10 group-hover:w-full group-hover:opacity-[0.05]';
            el.appendChild(bgHover);

            const info = document.createElement('div');
            info.innerHTML = `<h4 class="font-heading font-semibold text-xl tracking-[0.5px] mb-1 text-[#1e4a30]">${item.name}</h4>`;
            el.appendChild(info);

            if (item.price) {
                const price = document.createElement('span');
                price.className = 'font-bold text-white bg-[#1e4a30] font-body text-[1.1rem] py-2 px-4 rounded-lg shadow-sm';
                price.textContent = item.price;
                el.appendChild(price);
            }
            
            menuGrid.appendChild(el);
            setTimeout(() => el.classList.add('active'), 10);
        });
    }

    tabBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            tabBtns.forEach(t => t.classList.remove('active'));
            e.currentTarget.classList.add('active');
            const category = e.currentTarget.dataset.category;
            if (mobileSelect) mobileSelect.value = category;
            renderMenu(category);
        });
    });

    if (mobileSelect) {
        mobileSelect.addEventListener('change', (e) => {
            const category = e.target.value;
            tabBtns.forEach(t => {
                t.classList.remove('active');
                if (t.dataset.category === category) t.classList.add('active');
            });
            renderMenu(category);
        });
    }

    // Set first tab active
    if (tabBtns.length > 0) tabBtns[0].classList.add('active');
    renderMenu('chicken');
</script>
