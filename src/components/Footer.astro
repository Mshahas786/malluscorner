<footer class="bg-primary text-white relative overflow-hidden">
    <!-- Kerala kasavu top border -->
    <div class="h-2 bg-gradient-to-r from-gold/0 via-gold to-gold/0"></div>
    
    <div class="py-12 md:py-16">
        <div class="w-full max-w-5xl mx-auto px-4 sm:px-6 text-center">
            <!-- Logo & tagline -->
            <div class="mb-6">
                <span class="text-gold text-3xl block mb-2">🪷</span>
                <h3 class="font-heading text-2xl font-bold text-white mb-1">Mallu's Corner</h3>
                <p class="text-white/40 text-xs uppercase tracking-[3px]">Taste of God's Own Country</p>
            </div>
            
            <!-- Quick links -->
            <div class="flex flex-wrap justify-center gap-4 sm:gap-6 mb-8">
                <a href="#home" class="text-white/60 text-sm hover:text-gold transition-colors">Home</a>
                <a href="#about" class="text-white/60 text-sm hover:text-gold transition-colors">Our Story</a>
                <a href="#menu" class="text-white/60 text-sm hover:text-gold transition-colors">Menu</a>
                <a href="#gallery" class="text-white/60 text-sm hover:text-gold transition-colors">Gallery</a>
                <a href="#contact" class="text-white/60 text-sm hover:text-gold transition-colors">Contact</a>
            </div>
            
            <!-- Social links -->
            <div class="flex justify-center gap-4 mb-8">
                <a href="https://www.facebook.com/share/15VG1eYjHH/" target="_blank" aria-label="Facebook" class="w-10 h-10 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-gold hover:bg-gold hover:text-primary hover:border-gold transition-all text-sm">f</a>
                <a href="https://www.instagram.com/mallus_corner.nz" target="_blank" aria-label="Instagram" class="w-10 h-10 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-gold hover:bg-gold hover:text-primary hover:border-gold transition-all text-sm">ig</a>
            </div>
            
            <!-- Copyright -->
            <div class="border-t border-white/10 pt-6">
                <p class="text-white/30 text-xs">&copy; 2024 Mallu's Corner Restaurant. All rights reserved.</p>
                <p class="text-white/20 text-xs mt-1">147/149 Ohaupo Road, Melville, Hamilton 3206 | 📞 07 843 0307</p>
            </div>
        </div>
    </div>
</footer>

<button id="back-to-top" class="fixed bottom-5 right-5 w-12 h-12 bg-gold text-primary rounded-full text-lg font-bold flex items-center justify-center shadow-xl opacity-0 invisible transition-all duration-300 z-[99] hover:bg-[#e8b545] hover:-translate-y-1 hover:shadow-2xl" aria-label="Back to top" style="opacity: 0; visibility: hidden;">↑</button>

<script>
    const backToTop = document.getElementById('back-to-top');
    if (backToTop) {
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                backToTop.style.opacity = '1';
                backToTop.style.visibility = 'visible';
            } else {
                backToTop.style.opacity = '0';
                backToTop.style.visibility = 'hidden';
            }
        });

        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }
</script>
