---
---
<footer class="bg-[#1e4a30] text-white py-12 text-center">
    <div class="w-full max-w-5xl mx-auto px-5">
        <img src="https://assets.zyrosite.com/AoPvRzBqp7C1DEXR/ai-logo-mk3zR0ZJyRI9L5j4.svg" alt="Footer Logo" class="h-10 mx-auto mb-5 brightness-0 invert opacity-80">
        <div class="flex justify-center gap-6 mb-5">
            <a href="https://www.facebook.com/share/15VG1eYjHH/" target="_blank" aria-label="Facebook" class="text-[#dca43b] text-sm uppercase font-medium tracking-wider hover:text-white transition-colors">Facebook</a>
            <a href="https://www.instagram.com/mallus_corner.nz" target="_blank" aria-label="Instagram" class="text-[#dca43b] text-sm uppercase font-medium tracking-wider hover:text-white transition-colors">Instagram</a>
        </div>
        <p class="text-white/40 text-xs">&copy; 2024 Mallu's Corner Restaurant. All rights reserved.</p>
    </div>
</footer>

<button id="back-to-top" class="fixed bottom-5 right-5 w-10 h-10 bg-[#1e4a30] text-white rounded-full text-sm flex items-center justify-center shadow-lg opacity-0 invisible transition-all duration-300 z-[99] hover:bg-[#2d6b46] hover:-translate-y-1 [&.show]:opacity-100 [&.show]:visible" aria-label="Back to top">↑</button>

<script>
    const backToTop = document.getElementById('back-to-top');
    if (backToTop) {
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                backToTop.classList.add('show');
            } else {
                backToTop.classList.remove('show');
            }
        });

        backToTop.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }
</script>
