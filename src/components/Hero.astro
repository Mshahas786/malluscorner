<section id="home" class="relative min-h-screen flex items-center pt-20 text-white overflow-hidden py-20 md:py-28">
    <div class="absolute inset-0 -z-10 bg-cover bg-center bg-[linear-gradient(rgba(30,74,48,0.8),rgba(30,74,48,0.9)),url('https://images.unsplash.com/photo-1589187151003-0dd55769239b?auto=format&fit=crop&w=1200&q=80')]"></div>
    <div class="w-full max-w-7xl mx-auto px-5 flex flex-col">
        <div class="max-w-[600px] text-center mx-auto reveal">
            <span class="block text-[#dca43b] font-semibold tracking-[2px] uppercase mb-4 text-sm md:text-base">Welcome to Mallu's Corner</span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading leading-tight mb-5 text-white">Experience the Flavors of <span class="text-[#dca43b]">Kerala</span></h1>
            <p class="text-[1.1rem] mb-8 opacity-90 leading-relaxed font-light">Discover our unique blend of Kerala, Chinese, and Arabic cuisine in a warm, inviting atmosphere. Join us for a culinary journey that delights every palate.</p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="#menu" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-medium text-base transition-all duration-300 border-2 border-transparent bg-[#c75438] text-white shadow-md hover:bg-[#b0462e] hover:-translate-y-0.5 hover:shadow-lg">View Full Menu</a>
                <a href="tel:078430307" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-medium text-base transition-all duration-300 border-2 border-white text-white hover:bg-white hover:text-[#1e4a30]">Order Takeaway</a>
            </div>
        </div>
    </div>
    <a href="#about" class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white text-2xl animate-bounce" aria-label="Scroll down">↓</a>
</section>
