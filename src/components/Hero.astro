---
---
<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
        <img 
            src="/images/kerala-backwater-hero.png" 
            alt="Kerala Backwaters" 
            class="w-full h-full object-cover"
            fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-primary/80 via-primary/60 to-primary/90"></div>
    </div>
    
    <!-- Subtle gold corner accents -->
    <div class="absolute top-0 left-0 w-24 h-24 border-t-2 border-l-2 border-gold/20 rounded-tl-3xl m-4 hidden md:block"></div>
    <div class="absolute top-0 right-0 w-24 h-24 border-t-2 border-r-2 border-gold/20 rounded-tr-3xl m-4 hidden md:block"></div>
    <div class="absolute bottom-16 left-0 w-24 h-24 border-b-2 border-l-2 border-gold/20 rounded-bl-3xl m-4 hidden md:block"></div>
    <div class="absolute bottom-16 right-0 w-24 h-24 border-b-2 border-r-2 border-gold/20 rounded-br-3xl m-4 hidden md:block"></div>
    
    <div class="w-full max-w-4xl mx-auto px-4 sm:px-6 text-center relative z-10 py-32 md:py-0 reveal">
        <!-- Kerala cultural badge -->
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-5 py-2 mb-8 border border-white/10">
            <span class="text-gold text-lg">🪷</span>
            <span class="text-gold font-medium text-xs uppercase tracking-[4px]">Taste of God's Own Country</span>
            <span class="text-gold text-lg">🪷</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-bold leading-[1.1] mb-6 text-white drop-shadow-lg">
            Authentic Kerala<br>Cuisine in <span class="text-gold italic">Hamilton</span>
        </h1>
        
        <p class="text-base sm:text-lg md:text-xl mb-10 text-white/80 max-w-xl mx-auto leading-relaxed font-light">
            A unique blend of Kerala, Chinese & Arabic flavours — hand-crafted with love and tradition.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#menu" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full font-semibold text-sm transition-all duration-300 bg-gold text-primary shadow-lg hover:bg-[#e8b545] hover:-translate-y-1 hover:shadow-2xl">
                🍽️ View Our Menu
            </a>
            <a href="tel:078430307" class="inline-flex items-center justify-center px-8 py-3.5 rounded-full font-semibold text-sm transition-all duration-300 border-2 border-gold/40 text-white hover:bg-gold/10 hover:border-gold">
                📞 Order Takeaway
            </a>
        </div>
        
        <!-- Mini info bar -->
        <div class="mt-12 flex flex-wrap justify-center gap-6 text-white/60 text-xs sm:text-sm font-medium">
            <span class="flex items-center gap-2"><span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span> Open 7 Days</span>
            <span>🕐 12:00 PM – 9:00 PM</span>
            <span>📍 Hamilton, NZ</span>
        </div>
    </div>
    
    <a href="#about" class="absolute bottom-8 left-1/2 -translate-x-1/2 w-8 h-12 border-2 border-gold/40 rounded-full flex justify-center pt-2 hover:border-gold transition-colors" aria-label="Scroll down">
        <span class="block w-1.5 h-1.5 bg-gold rounded-full animate-bounce"></span>
    </a>
</section>
